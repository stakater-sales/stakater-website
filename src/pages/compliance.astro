---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import CTA from '../components/sections/CTA.astro';

const certifications = [
  { name: 'SOC 2 Type II', description: 'Security, availability, and confidentiality controls independently audited.', status: 'In Progress' },
  { name: 'ISO 27001', description: 'Information security management system certified.', status: 'Planned' },
  { name: 'GDPR', description: 'All data processing aligned with EU GDPR requirements. Data stays in EU regions.', status: 'Compliant' },
  { name: 'CIS Benchmarks', description: 'Kubernetes clusters hardened to CIS Benchmark Level 2 standards.', status: 'Compliant' },
];
---
<BaseLayout title="Compliance" description="Stakater's compliance posture — GDPR, SOC2, ISO 27001, and Kubernetes security benchmarks.">
  <PageHero label="Compliance" headline="Security and compliance, built in" highlightWord="built in"
    subtext="We take security seriously across our products, services, and internal operations. Here's our current compliance posture." />
  <section class="py-16 lg:py-24">
    <div class="container-site max-w-3xl">
      <div class="space-y-4 mb-16">
        {certifications.map((c, i) => (
          <div class="card p-6 flex items-start justify-between gap-4 animate-on-scroll" style={`animation-delay:${i*80}ms`}>
            <div>
              <h3 class="font-display font-bold text-text-primary mb-1">{c.name}</h3>
              <p class="text-sm text-text-secondary">{c.description}</p>
            </div>
            <span class={`flex-shrink-0 text-xs font-mono px-3 py-1 rounded-full border font-semibold
              ${c.status === 'Compliant' ? 'bg-green-500/10 text-green-400 border-green-500/20'
              : c.status === 'In Progress' ? 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20'
              : 'bg-surface text-text-muted border-surface-border'}`}>
              {c.status}
            </span>
          </div>
        ))}
      </div>
      <div class="card p-8 animate-on-scroll">
        <h2 class="font-display text-xl font-black text-text-primary mb-4">Questions about compliance?</h2>
        <p class="text-text-secondary text-sm mb-6">We're happy to provide compliance documentation, answer security questionnaires, and support your vendor assessment process.</p>
        <a href="/contact" class="btn-primary">Contact our security team</a>
      </div>
    </div>
  </section>
  <CTA />
</BaseLayout>
