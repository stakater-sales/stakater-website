---
import BaseLayout from '../layouts/BaseLayout.astro';
const FORMSPREE_ID = import.meta.env.PUBLIC_FORMSPREE_ID || 'YOUR_FORMSPREE_ID';
---

<BaseLayout title="Contact Us" description="Describe your Kubernetes setup and we'll map the next step. Talk to Stakater's platform engineering experts.">
  <div class="py-16 lg:py-24">
    <div class="container-site">
      <div class="max-w-2xl mx-auto">
        <div class="mb-12 animate-on-scroll">
          <p class="section-label mb-3">Contact</p>
          <h1 class="font-display text-display-lg font-black text-text-primary mb-4">
            Let's talk<br />
            <span class="text-brand-red">Kubernetes.</span>
          </h1>
          <p class="text-text-secondary">Describe your setup and we'll map the next step. No sales pressure — just a real conversation with engineers who know this stuff.</p>
        </div>

        <div class="card p-8 animate-on-scroll delay-100">
          <form id="contact-form" action={`https://formspree.io/f/${FORMSPREE_ID}`} method="POST" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-semibold text-text-primary mb-2">Name</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-surface-border text-text-primary placeholder-text-muted focus:outline-none focus:border-brand-red transition-colors text-sm"
                  placeholder="Your name" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-text-primary mb-2">Work Email</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-surface-border text-text-primary placeholder-text-muted focus:outline-none focus:border-brand-red transition-colors text-sm"
                  placeholder="you@company.com" />
              </div>
            </div>

            <div>
              <label for="company" class="block text-sm font-semibold text-text-primary mb-2">Company</label>
              <input type="text" id="company" name="company"
                class="w-full px-4 py-3 rounded-lg bg-surface border border-surface-border text-text-primary placeholder-text-muted focus:outline-none focus:border-brand-red transition-colors text-sm"
                placeholder="Your company" />
            </div>

            <div>
              <label for="interest" class="block text-sm font-semibold text-text-primary mb-2">What are you interested in?</label>
              <select id="interest" name="interest"
                class="w-full px-4 py-3 rounded-lg bg-surface border border-surface-border text-text-primary focus:outline-none focus:border-brand-red transition-colors text-sm appearance-none">
                <option value="">Select an option</option>
                <option>Stakater Cloud (Managed Platform)</option>
                <option>Cloud Orchestrator (VMware Exit)</option>
                <option>Multi-Tenant Operator (MTO)</option>
                <option>Platform Engineering Services</option>
                <option>Kubernetes Consulting</option>
                <option>AKS / EKS / Rancher / OpenShift Enablement</option>
                <option>Something else</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-text-primary mb-2">Describe your setup</label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-lg bg-surface border border-surface-border text-text-primary placeholder-text-muted focus:outline-none focus:border-brand-red transition-colors text-sm resize-none"
                placeholder="Tell us about your current Kubernetes setup, team size, key challenges, and what outcome you're looking for..."></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center py-3.5 text-base">
              Send Message
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </button>
          </form>
        </div>

        <!-- Office info -->
        <div class="mt-12 flex flex-col sm:flex-row gap-6 animate-on-scroll delay-200">
          <div class="card p-6 flex-1">
            <p class="text-xs font-mono text-text-muted uppercase tracking-wider mb-2">Office</p>
            <p class="text-sm text-text-secondary">David Bagares gata 26A<br />111 38 Stockholm, Sweden</p>
          </div>
          <div class="card p-6 flex-1">
            <p class="text-xs font-mono text-text-muted uppercase tracking-wider mb-2">Docs & GitHub</p>
            <div class="space-y-1">
              <a href="https://docs.stakater.com" class="block text-sm text-brand-red hover:underline">docs.stakater.com</a>
              <a href="https://github.com/stakater" class="block text-sm text-brand-red hover:underline">github.com/stakater</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
