---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/sections/CTA.astro';
import { formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies', ({ data }) => !data.draft);
  return studies.map(cs => ({ params: { slug: cs.slug }, props: { cs } }));
}

const { cs } = Astro.props;
const { Content } = await cs.render();
const { company, industry, initials, logo, outcome, challenge, solution, metrics, services, publishedAt } = cs.data;
---

<BaseLayout
  title={`${company} Case Study`}
  description={outcome}
  type="article"
  publishedAt={publishedAt}
>
  <article class="py-16 lg:py-24">
    <div class="container-site">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-text-muted font-mono mb-10">
        <a href="/" class="hover:text-text-primary transition-colors">Home</a>
        <span>/</span>
        <a href="/case-studies" class="hover:text-text-primary transition-colors">Case Studies</a>
        <span>/</span>
        <span class="text-text-secondary">{company}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <!-- Main content -->
        <div class="lg:col-span-2">
          <!-- Header -->
          <div class="flex items-center gap-4 mb-6">
            {logo ? (
              <img src={logo} alt={company} class="h-12 object-contain" />
            ) : (
              <div class="w-14 h-14 rounded-xl bg-brand-red/10 border border-brand-red/20 flex items-center justify-center flex-shrink-0">
                <span class="font-display font-black text-brand-red text-lg">{initials}</span>
              </div>
            )}
            <div>
              <h1 class="font-display text-display-md font-black text-text-primary">{company}</h1>
              <p class="text-sm font-mono text-text-muted">{industry}</p>
            </div>
          </div>

          <!-- Pull quote -->
          <blockquote class="border-l-2 border-brand-red pl-6 mb-10">
            <p class="text-lg text-text-secondary leading-relaxed italic">"{outcome}"</p>
          </blockquote>

          <!-- Content -->
          <div class="prose-stakater">
            {challenge && (
              <>
                <h2>The Challenge</h2>
                <p>{challenge}</p>
              </>
            )}
            {solution && (
              <>
                <h2>The Solution</h2>
                <p>{solution}</p>
              </>
            )}
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Metrics -->
          {metrics.length > 0 && (
            <div class="card p-6">
              <h3 class="font-display text-sm font-bold text-text-muted uppercase tracking-wider mb-4 font-mono">Key Results</h3>
              <div class="space-y-4">
                {metrics.map(m => (
                  <div class="text-center p-4 rounded-lg bg-brand-red/5 border border-brand-red/10">
                    <div class="font-display text-3xl font-black text-brand-red">{m.value}</div>
                    <div class="text-sm text-text-secondary mt-1">{m.label}</div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Services used -->
          {services.length > 0 && (
            <div class="card p-6">
              <h3 class="font-display text-sm font-bold text-text-muted uppercase tracking-wider mb-4 font-mono">Services Used</h3>
              <div class="flex flex-wrap gap-2">
                {services.map(s => (
                  <span class="text-xs px-3 py-1.5 rounded-md bg-surface border border-surface-border text-text-secondary font-mono">{s}</span>
                ))}
              </div>
            </div>
          )}

          <!-- CTA card -->
          <div class="card p-6 bg-gradient-to-br from-brand-red/8 to-background-card border-brand-red/20">
            <p class="font-display font-black text-text-primary mb-2">Want results like this?</p>
            <p class="text-sm text-text-secondary mb-4">Tell us about your Kubernetes setup.</p>
            <a href="/contact" class="btn-primary w-full justify-center text-sm py-2.5">
              Talk to us
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>

          <p class="text-xs text-text-muted font-mono text-center">{formatDate(publishedAt)}</p>
        </aside>
      </div>
    </div>
  </article>

  <CTA />
</BaseLayout>
