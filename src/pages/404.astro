---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist." noindex={true}>
  <div class="min-h-[80vh] flex items-center justify-center relative">
    <div class="absolute inset-0 bg-grid opacity-40"></div>
    <div class="absolute inset-0 bg-hero-radial"></div>
    <div class="container-site text-center relative z-10">
      <p class="font-mono text-brand-red text-sm font-semibold tracking-widest uppercase mb-4">404</p>
      <h1 class="font-display text-display-xl font-black text-text-primary mb-6">
        Page not<br /><span class="text-brand-red">found.</span>
      </h1>
      <p class="text-text-secondary text-lg max-w-md mx-auto mb-10">
        This page doesn't exist or may have moved. Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="btn-primary text-base px-8 py-3.5">Go Home</a>
        <a href="/blog" class="btn-secondary text-base px-8 py-3.5">Read the Blog</a>
        <a href="/contact" class="btn-ghost text-base px-8 py-3.5">Contact Us</a>
      </div>
    </div>
  </div>
</BaseLayout>
