  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Secure by Default', description: 'Even the starter cluster follows security best practices — pod security, RBAC, and network policies configured.' },
];
const process = [
  { step: '01', title: 'Kickoff', description: 'Half-day session to understand your team, cloud, and first workload.' },
  { step: '02', title: 'Build', description: 'Provision and configure your cluster. 2-3 days.' },
  { step: '03', title: 'Train', description: 'Hands-on training with your team on the live cluster.' },
  { step: '04', title: 'Support', description: '30 days of follow-up support while you find your feet.' },
];
const deliverables = [
  { title: 'Running Kubernetes cluster', description: 'Configured, secured, and ready for your workloads.' },
  { title: 'First application deployed', description: 'End-to-end GitOps flow demonstrated with a real app.' },
  { title: 'Operations runbook pack', description: 'Essential runbooks for common operations your team will need.' },
  { title: '30-day engineer access', description: 'Direct Slack access for questions during your first month.' },
];
const related = [
  { label: 'KubeDeploy', href: '/services/kube-deploy', description: 'Full platform deployment' },
  { label: 'KubeDesign', href: '/services/kube-design', description: 'Architecture-first approach' },
  { label: 'KubeCare', href: '/services/kube-care', description: 'Ongoing operations' },
];
---
<ServiceLayout
  title="KubeStart"
  description="Get started with Kubernetes fast. Rapid cluster setup, hands-on team training, and 30 days of follow-up support from Stakater's engineers."
  label="Services" headline="From zero to Kubernetes in weeks" highlightWord="Kubernetes in weeks"
  subtext="KubeStart gets your team from Kubernetes-curious to Kubernetes-confident — with a running cluster, hands-on training, and a real workload deployed."
  {features} {process} {deliverables} {related}
  ctaHeadline="Ready to get started?"
  ctaSubtext="Tell us about your team and we'll scope a KubeStart engagement."
/>
