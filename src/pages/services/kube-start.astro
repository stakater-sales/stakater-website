  { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Rapid Cluster Setup', description: 'Production-ready cluster in days, not weeks. We provision, configure, and validate everything.' },
  { icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', title: 'Hands-On Training', description: 'Two days of hands-on training with your team. Real workloads, real scenarios, real learning.' },
  { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4', title: 'Starter Runbooks', description: 'Essential day-2 runbooks for common operations — upgrades, scaling, debugging, and incident response.' },
  { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'First App Deployed', description: 'We deploy your first real workload to the cluster together. You see GitOps work end-to-end.' },
