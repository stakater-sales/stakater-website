---
import ProductLayout from '../../layouts/ProductLayout.astro';

const features = [
  { icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', title: 'VM + Kubernetes, Unified', description: 'Orchestrate both virtual machines and Kubernetes workloads from a single control plane. No need to choose one or the other.' },
  { icon: 'M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1', title: 'VMware Exit Path', description: 'Migrate off VMware licensing without ripping and replacing your entire infrastructure. Phased migration, zero downtime.' },
  { icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z', title: 'Full Automation API', description: 'Terraform providers, Ansible collections, and a REST API for every operation. Your infra as code, completely.' },
  { icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z', title: 'On-Prem or Any Cloud', description: 'Deploy on your own hardware, in a colocation, or on any public cloud. You own the infrastructure, we run the orchestration.' },
  { icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z', title: 'Compliance & Sovereignty', description: 'Keep data within your own perimeter. No cloud vendor lock-in, full audit trails, and compliance documentation.' },
  { icon: 'M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12', title: 'Self-Service for Teams', description: 'Developer self-service portal for provisioning VMs and clusters — with guardrails that keep things clean.' },
];

const metrics = [
  { value: '0', label: 'Vendor Lock-in', sub: 'Full ownership' },
  { value: '60%', label: 'Cost Reduction', sub: 'vs VMware licensing' },
  { value: '100%', label: 'API-Driven', sub: 'Every operation' },
  { value: '5min', label: 'VM Provisioning', sub: 'Self-service' },
];

const useCases = [
  { title: 'VMware cost reduction', description: 'VMware licensing renewals are expensive. SCO gives you the same VM capabilities on open-source infrastructure.' },
  { title: 'Hybrid cloud operations', description: 'Run some workloads on-prem, some in the cloud, all managed from one control plane.' },
  { title: 'Telcos and data-intensive industries', description: 'Manage thousands of VMs and containers from a single pane of glass with full network control.' },
  { title: 'Regulated on-prem environments', description: 'For organisations that cannot send workloads to a public cloud for compliance reasons.' },
];
---

<ProductLayout
  title="Cloud Orchestrator"
  description="Run and automate your own cloud for VMs and Kubernetes. Without VMware. Stakater Cloud Orchestrator gives you full infrastructure ownership with modern automation."
  label="Products"
  headline="Your own cloud. Without VMware."
  highlightWord="Without VMware."
  subtext="Stakater Cloud Orchestrator lets you run and automate VMs and Kubernetes on your own infrastructure — with the automation and self-service of a public cloud, at a fraction of the cost."
  badge="VMware Exit"
  tag="SCO"
  primaryCta={{ label: 'Plan your VMware Exit', href: '/contact' }}
  secondaryCta={{ label: 'Download Guide', href: '/vmware-exit-guide' }}
  {features} {metrics} {useCases}
/>
