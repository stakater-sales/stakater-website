---
import ProductLayout from '../../layouts/ProductLayout.astro';

const features = [
  { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Enterprise Security by Default', description: 'SOC2-ready, RBAC enforced, network policies, audit logging, and encryption at rest — all configured from day one.' },
  { icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10', title: 'Multi-Tenant by Design', description: 'Enforce tenant isolation with quotas, RBAC, and network segmentation. Teams get self-service without stepping on each other.' },
  { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', title: 'GitOps-Native Operations', description: 'Every cluster change is a Git commit. ArgoCD and Flux pre-integrated. Full audit trail out of the box.' },
  { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', title: 'Observability Stack Included', description: 'Prometheus, Grafana, Alertmanager, Loki — pre-wired and ready. No weeks of setup before you can see your own system.' },
  { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Auto-Scaling & Cost Control', description: 'Cluster autoscaler, VPA, HPA — all configured. Rightsizing recommendations and cost dashboards included.' },
  { icon: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z', title: '24/7 Stakater Operations', description: 'Our SRE team monitors and responds around the clock. Upgrades, patches, and incident response — handled.' },
];

const metrics = [
  { value: '99.9%', label: 'Uptime SLA', sub: 'Guaranteed' },
  { value: '<15min', label: 'Incident Response', sub: 'P1 issues' },
  { value: '100%', label: 'GitOps Driven', sub: 'Every change in Git' },
  { value: '24/7', label: 'SRE Coverage', sub: 'Always on' },
];

const useCases = [
  { title: 'Teams escaping VMware', description: 'Move from VMware to a modern, managed Kubernetes cloud without rebuilding your entire operation from scratch.' },
  { title: 'Regulated industries', description: 'Financial services, healthcare, and public sector teams that need compliance documentation from day one.' },
  { title: 'Platform teams without headcount', description: "You need enterprise Kubernetes but can't staff a full SRE team. We're your platform team." },
  { title: 'Multi-team enterprises', description: 'Ten teams sharing one cluster. Stakater Cloud keeps them isolated, productive, and out of each other\'s way.' },
];
---

<ProductLayout
  title="Stakater Cloud"
  description="Managed OpenShift and Kubernetes built for governance, multi-tenancy, and enterprise scale. Run cloud-native without the operational burden."
  label="Products"
  headline="Managed Kubernetes built for enterprise governance"
  highlightWord="enterprise governance"
  subtext="Run OpenShift and Kubernetes on a managed cloud with security, multi-tenancy, and GitOps baked in. Focus on your applications — we handle the platform."
  badge="Managed Platform"
  tag="Stakater Cloud"
  primaryCta={{ label: 'Explore the Platform', href: '/contact' }}
  secondaryCta={{ label: 'View Case Studies', href: '/case-studies' }}
  {features} {metrics} {useCases}
/>
