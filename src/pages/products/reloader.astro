---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRepoStats, formatCount } from '../../lib/github';

const stats = await getRepoStats('stakater', 'Reloader');
const starCount = stats.stars > 0 ? formatCount(stats.stars) : '9.9k';

const comparisonRows = [
  { capability: 'Full Reloader functionality',                          oss: true,  ent: true  },
  { capability: 'Community support (GitHub Issues)',                    oss: true,  ent: true  },
  { capability: 'CVE-scanned, signed container image',                  oss: false, ent: true  },
  { capability: 'SBOM & artifact provenance',                           oss: false, ent: true  },
  { capability: 'SLA-backed support with response times',               oss: false, ent: true  },
  { capability: 'Dedicated escalation channel',                         oss: false, ent: true  },
  { capability: 'Security advisory notifications',                      oss: false, ent: true  },
  { capability: 'Upgrade guidance & compatibility checks',              oss: false, ent: true  },
  { capability: 'Compliance-ready artifact chain (SOC 2 / ISO 27001)',  oss: false, ent: true  },
];

const personas = [
  {
    icon: '⚙️',
    title: 'Platform Engineering',
    sub: 'Running Reloader across 10+ clusters',
    body: 'You need guaranteed compatibility on every Kubernetes upgrade, a stable image channel you can pin, and someone to call when an edge case surfaces at scale.',
  },
  {
    icon: '🔒',
    title: 'Security & Compliance',
    sub: 'Prepping for a SOC 2 or ISO 27001 audit',
    body: 'Your auditor wants verified image provenance, SBOMs, and a documented CVE response process. The OSS image alone doesn\'t give you that paper trail.',
  },
  {
    icon: '📟',
    title: 'SREs at Scale',
    sub: 'Can\'t afford an unpatched controller incident',
    body: 'Reloader sits in the critical path for config and secret rotation. When something breaks during a cert rotation at 2am, you need a human on the other end, not a GitHub issue.',
  },
];

const testimonials = [
  {
    quote: 'The cert-manager + Reloader combo is gold. Renewed certs, live and hassle-free.',
    author: 'SRE · SaaS Company',
    source: 'Via Cloud Native Now, 2025',
  },
  {
    quote: 'The Secrets Store CSI Driver documentation recommends Reloader by name as the solution for restarting pods after secret rotation.',
    author: 'Secrets Store CSI Driver · Official Docs',
    source: 'secrets-store-csi-driver.sigs.k8s.io',
  },
  {
    quote: 'Reloader is included in KodeKloud\'s official Kubernetes Troubleshooting curriculum — standard curriculum for 100K+ engineers learning production Kubernetes.',
    author: 'KodeKloud · Kubernetes Training Platform',
    source: 'notes.kodekloud.com',
  },
];

const ecosystem = [
  {
    category: 'GitOps',
    tools: [
      { name: 'ArgoCD',     description: 'Annotations strategy avoids triggering unwanted sync diffs during config reloads' },
      { name: 'Flux',       description: 'Works alongside Flux reconciliation without introducing config drift' },
      { name: 'Kustomize',  description: 'Annotation-based control works cleanly with Kustomize overlays and patches' },
    ],
  },
  {
    category: 'Deployment',
    tools: [
      { name: 'Argo Rollouts', description: 'Full support for progressive delivery rollout types alongside standard workloads' },
    ],
  },
  {
    category: 'Secrets',
    tools: [
      { name: 'External Secrets Operator', description: 'Restart workloads automatically when ESO syncs a new secret value from any backend' },
      { name: 'HashiCorp Vault',           description: 'Uniform restart mechanism across Vault Secrets Operator, CSI, and direct patterns' },
      { name: 'OpenBao',                   description: 'Open-source Vault fork — same Reloader integration path via ESO or CSI driver' },
      { name: 'Conjur',                    description: 'Works with CyberArk Conjur secrets surfaced via Kubernetes Secrets or ESO' },
      { name: 'AWS Secrets Manager',       description: 'Full rotation-to-restart pipeline via Secrets Store CSI or External Secrets Operator' },
      { name: 'Azure Key Vault',           description: 'Workload restarts triggered on AKV secret updates via CSI driver or ESO' },
      { name: 'Google Secret Manager',     description: 'Integrates via External Secrets Operator to restart pods on GCP secret rotation' },
    ],
  },
  {
    category: 'Config',
    tools: [
      { name: 'cert-manager', description: 'Automatically reloads workloads when TLS certificates are renewed in-cluster' },
    ],
  },
];

const steps = [
  {
    number: '01',
    title: 'Subscribe',
    body: 'Choose a support tier based on your cluster footprint and compliance requirements. No per-node pricing surprises.',
    action: 'Contact sales@stakater.com',
    href: 'mailto:sales@stakater.com',
  },
  {
    number: '02',
    title: 'Pull the certified image',
    body: 'Point your Helm values at the Enterprise registry. Same binary, hardened delivery chain. No manifest changes required.',
    code: true,
  },
  {
    number: '03',
    title: 'Get support',
    body: 'Direct access to the Stakater engineering team. Not a ticket queue — a dedicated channel with people who wrote the code.',
    action: 'SLA response times guaranteed',
  },
];

const faqs = [
  {
    q: 'Is it a different binary from OSS Reloader?',
    a: 'No. It is the same codebase and the same binary. The difference is the image delivery pipeline — Enterprise images are built in a hardened environment, scanned for CVEs, signed with cosign, and shipped with a full SBOM.',
  },
  {
    q: 'Do we need to change our Helm configuration?',
    a: 'Minimal changes only — you update the image registry reference to point to the Enterprise registry. All existing annotations and flags remain identical. Migration typically takes under 10 minutes.',
  },
  {
    q: 'What compliance frameworks does it support?',
    a: 'The image and artifact chain supports SOC 2 Type II, ISO 27001, and FedRAMP-aligned environments. We provide the provenance documentation required by most enterprise security audits.',
  },
  {
    q: 'How is support delivered?',
    a: 'Via a dedicated Slack channel with the Stakater engineering team, with SLA-defined response times based on your tier. For critical production issues, we have an escalation path to the engineers who wrote the code.',
  },
  {
    q: 'How is Enterprise priced?',
    a: 'Pricing is based on cluster footprint and support tier. There is no per-node or per-pod pricing. Contact sales@stakater.com for a quote based on your environment.',
  },
  {
    q: 'Can we stay on OSS and just buy support?',
    a: 'Yes — support-only tiers are available for teams that need the SLA and escalation path but have already addressed image verification through their own pipeline. Ask about this option in the sales conversation.',
  },
];
---

<BaseLayout
  title="Reloader Enterprise"
  description="The same controller your team already runs — with a CVE-signed image, SLA-backed support, and the team that built it on call."
>

  <!-- ───────────── HERO ───────────── -->
  <section class="relative pt-24 pb-20 lg:pt-32 lg:pb-28 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-40"></div>
    <div class="absolute inset-0 bg-hero-radial"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-red/40 to-transparent"></div>

    <div class="container-site relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-red/30 bg-brand-red/5 text-brand-red text-xs font-mono font-semibold tracking-wider uppercase mb-6 animate-on-scroll">
        stakater / reloader Enterprise
      </div>

      <h1 class="font-display text-display-xl lg:text-display-2xl font-black text-text-primary mb-4 animate-on-scroll delay-100">
        Reloader Enterprise
      </h1>
      <p class="font-display text-display-sm font-bold text-text-secondary mb-6 animate-on-scroll delay-150">
        "Reloader, <em class="text-brand-red not-italic">production-hardened</em> and fully supported"
      </p>
      <p class="text-lg text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed animate-on-scroll delay-200">
        The same controller your team already runs — with a CVE-signed image, SLA-backed support, and the team that built it on call.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4 mb-14 animate-on-scroll delay-300">
        <a href="/contact" class="btn-primary">Talk to Sales →</a>
        <a href="https://docs.stakater.com/reloader" target="_blank" rel="noopener noreferrer" class="btn-secondary">Read the Docs</a>
      </div>

      <!-- Hero stats -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 max-w-3xl mx-auto animate-on-scroll delay-400">
        {[
          { value: '24B+',           label: 'Docker Pulls' },
          { value: `${starCount}+`,  label: 'GitHub Stars' },
          { value: '7+',             label: 'Years in Production' },
          { value: 'Drop-in',        label: 'Replacement' },
        ].map(s => (
          <div class="card p-5 text-center">
            <div class="font-display text-2xl font-black text-brand-red mb-1">{s.value}</div>
            <div class="text-xs text-text-muted font-mono">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────── THE PROBLEM ───────────── -->
  <section class="py-20 lg:py-28 border-t border-surface-border bg-background-secondary">
    <div class="container-site">
      <div class="max-w-3xl mx-auto">
        <p class="section-label mb-4 animate-on-scroll">The Problem</p>
        <h2 class="font-display text-display-md font-black text-text-primary mb-6 animate-on-scroll">
          OSS is great. Until compliance asks questions.
        </h2>
        <p class="text-text-secondary leading-relaxed mb-10 animate-on-scroll">
          Reloader OSS is battle-tested and running in thousands of clusters. But when it's part of a regulated environment, the conversation shifts from "does it work?" to "can you prove it?"
        </p>
        <p class="text-text-secondary leading-relaxed mb-8 animate-on-scroll">
          These are the questions that OSS alone can't answer.
        </p>
        <ul class="space-y-4 animate-on-scroll">
          {[
            'Is this image CVE-clean and who\'s responsible if it\'s not?',
            'Can we pass our SOC 2 audit with an unverified container image?',
            'What happens when we hit a production edge case at 2am?',
            'Who do we escalate to when something breaks during a rotation?',
          ].map(q => (
            <li class="flex items-start gap-3 text-text-secondary">
              <span class="text-brand-red mt-1 flex-shrink-0">—</span>
              <span>{q}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ───────────── OSS vs ENTERPRISE TABLE ───────────── -->
  <section class="py-20 lg:py-28 border-t border-surface-border">
    <div class="container-site">
      <div class="max-w-3xl mx-auto">
        <p class="section-label mb-4 animate-on-scroll">Comparison</p>
        <h2 class="font-display text-display-md font-black text-text-primary mb-3 animate-on-scroll">
          Everything you need for production at scale
        </h2>
        <p class="text-text-secondary mb-10 animate-on-scroll">
          Enterprise is a drop-in replacement — same codebase, hardened delivery pipeline.
        </p>

        <div class="card overflow-hidden animate-on-scroll">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-surface-border">
                <th class="text-left px-6 py-4 text-text-muted font-mono font-semibold text-xs uppercase tracking-wider">Capability</th>
                <th class="px-6 py-4 text-center text-text-muted font-mono font-semibold text-xs uppercase tracking-wider">OSS</th>
                <th class="px-6 py-4 text-center text-brand-red font-mono font-semibold text-xs uppercase tracking-wider">Enterprise</th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row, i) => (
                <tr class={`border-b border-surface-border last:border-0 ${i % 2 === 0 ? '' : 'bg-surface/30'}`}>
                  <td class="px-6 py-4 text-text-secondary">{row.capability}</td>
                  <td class="px-6 py-4 text-center">
                    {row.oss
                      ? <span class="text-green-400 font-bold">✓</span>
                      : <span class="text-text-muted">—</span>
                    }
                  </td>
                  <td class="px-6 py-4 text-center">
                    {row.ent
                      ? <span class="text-brand-red font-bold">✓</span>
                      : <span class="text-text-muted">—</span>
                    }
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────── WHO IT'S FOR ───────────── -->
  <section class="py-20 lg:py-28 border-t border-surface-border bg-background-secondary">
    <div class="container-site">
      <p class="section-label mb-4 animate-on-scroll">Who It's For</p>
      <h2 class="font-display text-display-md font-black text-text-primary mb-12 animate-on-scroll">
        Built for teams who run Kubernetes seriously
      </h2>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {personas.map((p, i) => (
          <div class="card p-8 animate-on-scroll" style={`animation-delay:${i * 150}ms`}>
            <div class="text-3xl mb-4">{p.icon}</div>
            <h3 class="font-display text-lg font-black text-text-primary mb-1">{p.title}</h3>
            <p class="text-xs font-mono text-brand-red mb-4">{p.sub}</p>
            <p class="text-sm text-text-secondary leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────── COMMUNITY VALIDATION ───────────── -->
  <section class="py-20 lg:py-28 border-t border-surface-border">
    <div class="container-site">
      <p class="section-label mb-4 animate-on-scroll">Social Proof</p>
      <h2 class="font-display text-display-md font-black text-text-primary mb-4 animate-on-scroll">
        So trusted, the community asked for it in Kubernetes core
      </h2>
      <p class="text-text-secondary mb-12 animate-on-scroll">
        Here's what the community and ecosystem have said — unprompted.
      </p>

      <!-- Tim Hockin callout -->
      <div class="card p-8 mb-10 border-brand-red/20 bg-brand-red/5 animate-on-scroll">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-yellow-400">🏆</span>
          <span class="text-xs font-mono font-semibold text-text-muted uppercase tracking-wider">Highest Signal</span>
        </div>
        <p class="text-text-secondary leading-relaxed mb-4">
          In December 2024, a member of the official Kubernetes discussion forum proposed that Reloader be added to Kubernetes core, stating that reloading deployments on config changes "is needed very often." Tim Hockin — one of Kubernetes' original creators — responded by defending Reloader as the established ecosystem standard, arguing against adding it to core precisely because the ecosystem project already exists and serves the need well.
        </p>
        <p class="text-xs font-mono text-text-muted">
          — discuss.kubernetes.io, December 2024 · Tim Hockin, Google Distinguished Engineer & Kubernetes co-creator
        </p>
      </div>

      <!-- Testimonials -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class="card p-6 animate-on-scroll" style={`animation-delay:${i * 150}ms`}>
            <p class="text-text-secondary text-sm leading-relaxed mb-6 italic">"{t.quote}"</p>
            <div class="border-t border-surface-border pt-4">
              <p class="text-xs font-semibold text-text-primary">{t.author}</p>
              <p class="text-xs font-mono text-text-muted mt-0.5">{t.source}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────── ECOSYSTEM ───────────── -->
  <section class="py-20 lg:py-28 border-t border-surface-border bg-background-secondary">
    <div class="container-site">
      <p class="section-label mb-4 animate-on-scroll">Ecosystem</p>
      <h2 class="font-display text-display-md font-black text-text-primary mb-3 animate-on-scroll">
        Works with everything already in your stack
      </h2>
      <p class="text-text-secondary mb-12 animate-on-scroll">
        Reloader Enterprise is a drop-in component, not a new platform to adopt.
      </p>

      <div class="space-y-10">
        {ecosystem.map((group, gi) => (
          <div class="animate-on-scroll" style={`animation-delay:${gi * 100}ms`}>
            <h3 class="text-xs font-mono font-semibold text-brand-red uppercase tracking-widest mb-4">{group.category}</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {group.tools.map(tool => (
                <div class="card p-5">
                  <p class="font-semibold text-text-primary text-sm mb-1">{tool.name}</p>
                  <p class="text-xs text-text-secondary leading-relaxed">{tool.description}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────── HOW IT WORKS / GETTING STARTED ───────────── -->
  <section class="py-20 lg:py-28 border-t border-surface-border">
    <div class="container-site">
      <p class="section-label mb-4 animate-on-scroll">How It Works</p>
      <h2 class="font-display text-display-md font-black text-text-primary mb-12 animate-on-scroll">
        Three steps. Zero migration effort.
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Step 01 -->
        <div class="animate-on-scroll">
          <div class="text-4xl font-display font-black text-brand-red/20 mb-4">01</div>
          <h3 class="font-display text-lg font-black text-text-primary mb-3">Subscribe</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            Choose a support tier based on your cluster footprint and compliance requirements. No per-node pricing surprises.
          </p>
          <a href="mailto:sales@stakater.com" class="text-sm text-brand-red font-mono hover:underline">→ Contact sales@stakater.com</a>
        </div>

        <!-- Step 02 -->
        <div class="animate-on-scroll delay-150">
          <div class="text-4xl font-display font-black text-brand-red/20 mb-4">02</div>
          <h3 class="font-display text-lg font-black text-text-primary mb-3">Pull the certified image</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            Point your Helm values at the Enterprise registry. Same binary, hardened delivery chain. No manifest changes required.
          </p>
          <div class="bg-background-tertiary rounded-lg p-4 font-mono text-xs space-y-2 border border-surface-border">
            <p class="text-text-muted"># Before</p>
            <p class="text-text-secondary">image: stakater/reloader:latest</p>
            <p class="text-text-muted mt-2"># After</p>
            <p class="text-brand-red">image: enterprise.stakater.com/reloader:v1.x</p>
          </div>
        </div>

        <!-- Step 03 -->
        <div class="animate-on-scroll delay-300">
          <div class="text-4xl font-display font-black text-brand-red/20 mb-4">03</div>
          <h3 class="font-display text-lg font-black text-text-primary mb-3">Get support</h3>
          <p class="text-sm text-text-secondary leading-relaxed mb-4">
            Direct access to the Stakater engineering team. Not a ticket queue — a dedicated channel with people who wrote the code.
          </p>
          <p class="text-sm text-text-muted font-mono">→ SLA response times guaranteed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────── FAQ ───────────── -->
  <section class="py-20 lg:py-28 border-t border-surface-border bg-background-secondary">
    <div class="container-site">
      <div class="max-w-3xl mx-auto">
        <p class="section-label mb-4 animate-on-scroll">FAQ</p>
        <h2 class="font-display text-display-md font-black text-text-primary mb-12 animate-on-scroll">
          Common questions
        </h2>

        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <div class="card p-6 animate-on-scroll" style={`animation-delay:${i * 80}ms`}>
              <h3 class="font-display font-bold text-text-primary mb-3">{faq.q}</h3>
              <p class="text-sm text-text-secondary leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────── CLOSING CTA ───────────── -->
  <section class="py-20 lg:py-28 border-t border-surface-border relative overflow-hidden">
    <div class="absolute inset-0 bg-hero-radial opacity-50"></div>
    <div class="container-site relative z-10 text-center">
      <h2 class="font-display text-display-lg font-black text-text-primary mb-4 animate-on-scroll">
        Run Reloader with <em class="text-brand-red not-italic">confidence</em> and a number to call
      </h2>
      <p class="text-text-secondary max-w-xl mx-auto mb-10 animate-on-scroll">
        24 billion downloads means Reloader works. Enterprise means someone is accountable when it matters most.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4 animate-on-scroll">
        <a href="/contact" class="btn-primary">Talk to Sales →</a>
        <a href="https://docs.stakater.com/reloader" target="_blank" rel="noopener noreferrer" class="btn-secondary">Read the Docs</a>
      </div>
    </div>
  </section>

</BaseLayout>
