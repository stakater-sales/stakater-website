---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import CTA from '../components/sections/CTA.astro';

const faqs = [
  { q: 'Do you only work with OpenShift?', a: 'No — we work across OpenShift, upstream Kubernetes, AKS, EKS, and Rancher. We are Red Hat Premier Partners so we have deep OpenShift expertise, but we\'re not limited to it.' },
  { q: 'What size of companies do you work with?', a: 'Mostly mid-market to large enterprises — companies with 200-10,000+ employees running or planning to run Kubernetes at scale. We\'ve worked with telcos, financial services, healthcare, and public sector.' },
  { q: 'Do you offer managed services?', a: 'Yes — Stakater Cloud is our managed Kubernetes platform. KubeCare is our managed day-2 operations service for customers who want to own their cluster but outsource operations.' },
  { q: 'What is the difference between Reloader and Reloader Enterprise?', a: 'Reloader is open source and free. Reloader Enterprise adds a commercial SLA, priority support, and guaranteed patch response times. If you\'re running Reloader in critical production, Enterprise gives you the safety net.' },
  { q: 'Can you help us move off VMware?', a: 'Yes — Stakater Cloud Orchestrator (SCO) is specifically designed as a VMware replacement, letting you run VMs and Kubernetes on your own infrastructure without VMware licensing.' },
  { q: 'Where are you based?', a: 'Headquarters in Stockholm, Sweden. We work with customers across Europe and globally, primarily remote.' },
  { q: 'How do engagements typically start?', a: 'With a call where we understand your setup and goals. From there we propose the right engagement — whether that\'s a KubeAudit, a KubeDesign, or a full platform build. No cookie-cutter proposals.' },
];
---
<BaseLayout title="FAQs" description="Frequently asked questions about Stakater's Kubernetes services, products, and approach.">
  <PageHero label="FAQs" headline="Questions we get a lot" highlightWord="a lot"
    subtext="If you don't find what you need here, just reach out — we're easy to talk to." />
  <section class="py-16 lg:py-24">
    <div class="container-site max-w-3xl">
      <div class="space-y-3" id="faq-list">
        {faqs.map((faq, i) => (
          <div class="card overflow-hidden animate-on-scroll" style={`animation-delay:${i*60}ms`}>
            <button
              class="w-full flex items-start justify-between gap-4 p-6 text-left group"
              onclick="this.parentElement.classList.toggle('open')"
            >
              <span class="font-display font-bold text-text-primary group-hover:text-brand-red transition-colors">{faq.q}</span>
              <svg class="w-5 h-5 text-text-muted flex-shrink-0 mt-0.5 transition-transform faq-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-answer px-6 pb-0 max-h-0 overflow-hidden transition-all duration-300">
              <p class="text-text-secondary pb-6 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <script>
    document.querySelectorAll('#faq-list .card').forEach(card => {
      const observer = new MutationObserver(() => {
        const answer = card.querySelector('.faq-answer') as HTMLElement;
        const icon = card.querySelector('.faq-icon') as HTMLElement;
        if (card.classList.contains('open')) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
          icon.style.transform = 'rotate(180deg)';
        } else {
          answer.style.maxHeight = '0';
          icon.style.transform = '';
        }
      });
      observer.observe(card, { attributes: true, attributeFilter: ['class'] });
    });
  </script>
  <CTA headline="Still have questions?" subtext="Reach out — we respond fast." />
</BaseLayout>
