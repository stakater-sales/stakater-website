---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import FeaturedProducts from '../components/sections/FeaturedProducts.astro';
import Services from '../components/sections/Services.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import OpenSource from '../components/sections/OpenSource.astro';
import CTA from '../components/sections/CTA.astro';
import CaseStudyCard from '../components/case-studies/CaseStudyCard.astro';
import BlogCard from '../components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const featuredCaseStudies = (await getCollection('case-studies', ({ data }) => !data.draft && data.featured))
  .slice(0, 2);

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Platform Engineering"
  description="Stakater helps enterprises accelerate their cloud-native journey with Kubernetes services, managed platforms, and platform engineering expertise."
>
  <Hero />
  <Stats />
  <FeaturedProducts />
  <Services />

  <!-- Case Studies preview -->
  {featuredCaseStudies.length > 0 && (
    <section class="py-16 lg:py-24 border-t border-surface-border">
      <div class="container-site">
        <div class="mb-12 animate-on-scroll">
          <p class="section-label mb-3">Proof</p>
          <h2 class="font-display text-display-lg font-black text-text-primary">
            Real outcomes.<br />
            <span class="text-brand-red">Real teams.</span>
          </h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {featuredCaseStudies.map(cs => (
            <CaseStudyCard
              company={cs.data.company}
              industry={cs.data.industry}
              initials={cs.data.initials}
              logo={cs.data.logo}
              outcome={cs.data.outcome}
              metrics={cs.data.metrics}
              services={cs.data.services}
              href={`/case-studies/${cs.slug}`}
              featured={cs.data.featured}
            />
          ))}
        </div>
        <div class="mt-8 text-center animate-on-scroll">
          <a href="/case-studies" class="btn-secondary">View all case studies</a>
        </div>
      </div>
    </section>
  )}

  <Testimonials />
  <OpenSource />

  <!-- Blog preview -->
  {recentPosts.length > 0 && (
    <section class="py-16 lg:py-24 border-t border-surface-border">
      <div class="container-site">
        <div class="flex items-end justify-between mb-12 animate-on-scroll">
          <div>
            <p class="section-label mb-3">From the Blog</p>
            <h2 class="font-display text-display-md font-black text-text-primary">
              Platform engineering<br />thinking, in the open.
            </h2>
          </div>
          <a href="/blog" class="btn-ghost hidden sm:inline-flex">
            All posts
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {recentPosts.map(post => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              publishedAt={post.data.publishedAt}
              author={post.data.author}
              tags={post.data.tags}
              image={post.data.image}
              href={`/blog/${post.slug}`}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA />
</BaseLayout>
