---
---
<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background layers -->
  <div class="absolute inset-0 bg-grid opacity-100"></div>
  <div class="absolute inset-0 bg-hero-radial"></div>
  <!-- Red glow orb -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-brand-red/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container-site relative z-10 py-24 lg:py-32">
    <div class="max-w-5xl mx-auto text-center">
      <!-- Eyebrow label -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-brand-red/30 bg-brand-red-glow mb-8 animate-on-scroll">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-red animate-pulse"></span>
        <span class="text-xs font-mono font-semibold text-brand-red tracking-wider uppercase">Platform Engineering Experts</span>
      </div>

      <!-- Main headline -->
      <h1 class="font-display text-display-xl lg:text-[5.5rem] font-black leading-[1.02] tracking-[-0.04em] mb-6 animate-on-scroll delay-100">
        <span class="text-text-primary">Kubernetes.</span><br />
        <span class="text-text-primary">Implemented.</span>
        <span class="text-brand-red"> Secured.</span><br />
        <span class="text-text-primary">Supported.</span>
      </h1>

      <!-- Subheadline -->
      <p class="text-lg lg:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed mb-10 animate-on-scroll delay-200">
        Accelerate your cloud-native journey with battle-tested Kubernetes expertise —
        from platform design to day-2 operations at enterprise scale.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16 animate-on-scroll delay-300">
        <a href="/contact" class="btn-primary text-base px-8 py-3.5 shadow-glow-red">
          Discuss your Setup
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href="/services" class="btn-secondary text-base px-8 py-3.5">
          Explore Services
        </a>
      </div>

      <!-- Social proof bar -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10 animate-on-scroll delay-400">
        <div class="flex items-center gap-2 text-text-muted text-sm">
          <svg class="w-4 h-4 text-brand-red flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          <span>Red Hat Premier Partner</span>
        </div>
        <div class="hidden sm:block w-px h-4 bg-surface-border"></div>
        <div class="flex items-center gap-2 text-text-muted text-sm">
          <svg class="w-4 h-4 text-brand-red flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          <span>100+ Enterprise Customers</span>
        </div>
        <div class="hidden sm:block w-px h-4 bg-surface-border"></div>
        <div class="flex items-center gap-2 text-text-muted text-sm">
          <svg class="w-4 h-4 text-brand-red flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          <span>Open Source Roots</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent pointer-events-none"></div>
</section>
