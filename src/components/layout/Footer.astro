---
import { footerLinks } from '../../data/navigation';
---

<footer class="border-t border-surface-border mt-24">
  <div class="container-site py-16">
    <!-- Top: Logo + tagline + social -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 mb-12">
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4 group">
          <div class="w-8 h-8 bg-brand-red rounded-lg flex items-center justify-center">
            <span class="text-white font-display font-black text-sm">S</span>
          </div>
          <span class="font-display font-black text-xl text-text-primary tracking-tight">STAKATER</span>
        </a>
        <p class="text-text-secondary text-sm leading-relaxed max-w-xs mb-6">
          Kubernetes. Implemented. Secured. Supported. We help enterprises accelerate their cloud-native journey.
        </p>
        <div class="flex items-center gap-3">
          <a href="https://github.com/stakater" target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 rounded-lg border border-surface-border flex items-center justify-center text-text-muted hover:text-text-primary hover:border-surface-border-strong transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/stakater" target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 rounded-lg border border-surface-border flex items-center justify-center text-text-muted hover:text-text-primary hover:border-surface-border-strong transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://twitter.com/stakater" target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 rounded-lg border border-surface-border flex items-center justify-center text-text-muted hover:text-text-primary hover:border-surface-border-strong transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.631L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links grid -->
      <div class="lg:col-span-3 grid grid-cols-2 sm:grid-cols-4 gap-8">
        {Object.values(footerLinks).map((section) => (
          <div>
            <h4 class="text-xs font-mono font-semibold text-text-muted uppercase tracking-wider mb-4">{section.label}</h4>
            <ul class="space-y-2.5">
              {section.links.map((link) => (
                <li>
                  <a href={link.href} class="text-sm text-text-secondary hover:text-text-primary transition-colors">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="glow-line mb-8"></div>

    <!-- Bottom bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-text-muted">
        © {new Date().getFullYear()} Stakater AB. All rights reserved.
      </p>
      <p class="text-sm text-text-muted flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-brand-red" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
        </svg>
        David Bagares gata 26A, 111 38 Stockholm, Sweden
      </p>
    </div>
  </div>
</footer>
