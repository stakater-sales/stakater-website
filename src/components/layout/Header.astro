---
import { navigation } from '../../data/navigation';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="container-site">
    <nav class="flex items-center justify-between h-16 lg:h-18">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0 group" aria-label="Stakater Home">
        <div class="w-8 h-8 bg-brand-red rounded-lg flex items-center justify-center group-hover:shadow-glow-red-sm transition-all">
          <span class="text-white font-display font-black text-sm">S</span>
        </div>
        <span class="font-display font-black text-xl text-text-primary tracking-tight">STAKATER</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        <!-- Products -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-surface">
            {navigation.products.label}
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="w-72 bg-background-secondary border border-surface-border rounded-xl shadow-2xl overflow-hidden">
              <div class="p-2">
                {navigation.products.items.map((item) => (
                  <a href={item.href} class="flex items-start gap-3 p-3 rounded-lg hover:bg-surface transition-colors group/item">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2">
                        <span class="text-sm font-semibold text-text-primary group-hover/item:text-brand-red transition-colors">{item.label}</span>
                        <span class="text-xs px-1.5 py-0.5 rounded bg-brand-red-glow text-brand-red font-mono border border-brand-red/20">{item.tag}</span>
                      </div>
                      <p class="text-xs text-text-muted mt-0.5 leading-relaxed">{item.description}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Services -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-surface">
            {navigation.services.label}
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="w-[520px] bg-background-secondary border border-surface-border rounded-xl shadow-2xl overflow-hidden">
              <div class="p-4 grid grid-cols-2 gap-4">
                {navigation.services.groups.map((group) => (
                  <div>
                    <p class="text-xs font-mono font-semibold text-text-muted uppercase tracking-wider px-2 mb-2">{group.label}</p>
                    {group.items.map((item) => (
                      <a href={item.href} class="flex flex-col px-2 py-2 rounded-lg hover:bg-surface transition-colors group/item">
                        <span class="text-sm font-semibold text-text-primary group-hover/item:text-brand-red transition-colors">{item.label}</span>
                        <span class="text-xs text-text-muted">{item.description}</span>
                      </a>
                    ))}
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Resources -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-surface">
            {navigation.resources.label}
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="w-64 bg-background-secondary border border-surface-border rounded-xl shadow-2xl overflow-hidden">
              <div class="p-2">
                {navigation.resources.items.map((item) => (
                  <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener noreferrer' : undefined}
                     class="flex items-center justify-between px-3 py-2.5 rounded-lg hover:bg-surface transition-colors group/item">
                    <div>
                      <span class="text-sm font-semibold text-text-primary group-hover/item:text-brand-red transition-colors">{item.label}</span>
                      <p class="text-xs text-text-muted">{item.description}</p>
                    </div>
                    {item.external && (
                      <svg class="w-3.5 h-3.5 text-text-muted flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                    )}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Company -->
        <div class="relative group">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-surface">
            {navigation.company.label}
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="w-48 bg-background-secondary border border-surface-border rounded-xl shadow-2xl overflow-hidden">
              <div class="p-2">
                {navigation.company.items.map((item) => (
                  <a href={item.href} class="block px-3 py-2 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface rounded-lg transition-colors">
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a href={navigation.cta.href} class="hidden lg:inline-flex btn-primary text-sm py-2 px-5">
          {navigation.cta.label}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 text-text-secondary hover:text-text-primary transition-colors" aria-label="Open menu">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-background-secondary border-t border-surface-border">
    <div class="container-site py-4 space-y-1">
      <p class="text-xs font-mono text-text-muted uppercase tracking-wider px-3 py-2">Products</p>
      {navigation.products.items.map((item) => (
        <a href={item.href} class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-surface transition-colors">
          <span class="text-sm font-semibold text-text-primary">{item.label}</span>
          <span class="tag text-xs">{item.tag}</span>
        </a>
      ))}
      <div class="h-px bg-surface-border my-2"></div>
      <p class="text-xs font-mono text-text-muted uppercase tracking-wider px-3 py-2">Services</p>
      {navigation.services.groups.flatMap(g => g.items).map((item) => (
        <a href={item.href} class="block px-3 py-2 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface rounded-lg transition-colors">
          {item.label}
        </a>
      ))}
      <div class="h-px bg-surface-border my-2"></div>
      {navigation.resources.items.map((item) => (
        <a href={item.href} class="block px-3 py-2 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface rounded-lg transition-colors">
          {item.label}
        </a>
      ))}
      {navigation.company.items.map((item) => (
        <a href={item.href} class="block px-3 py-2 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface rounded-lg transition-colors">
          {item.label}
        </a>
      ))}
      <div class="h-px bg-surface-border my-2"></div>
      <a href={navigation.cta.href} class="btn-primary w-full justify-center mt-2">
        {navigation.cta.label}
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  // Sticky header with blur
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-background/90', 'backdrop-blur-md', 'border-b', 'border-surface-border');
    } else {
      header?.classList.remove('bg-background/90', 'backdrop-blur-md', 'border-b', 'border-surface-border');
    }
  }, { passive: true });

  // Mobile toggle
  mobileBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
