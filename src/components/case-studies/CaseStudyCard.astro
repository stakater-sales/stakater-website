---
/**
 * CaseStudyCard - Reusable case study card component
 *
 * Props come from a case study Markdown/MDX frontmatter.
 * To add a new case study, create a file in:
 *   src/content/case-studies/your-company.md
 * Then run the Claude Code prompt: /new-case-study
 */
interface Props {
  company: string;
  industry: string;
  logo?: string;
  initials: string;
  outcome: string;
  metrics?: { value: string; label: string }[];
  services: string[];
  href: string;
  featured?: boolean;
}
const { company, industry, logo, initials, outcome, metrics = [], services, href, featured = false } = Astro.props;
---

<a
  href={href}
  class={`group card p-8 flex flex-col transition-all duration-300
    ${featured ? 'lg:col-span-2 bg-gradient-to-br from-brand-red/8 to-background-card border-brand-red/20 hover:border-brand-red/40' : ''}`}
>
  <!-- Company header -->
  <div class="flex items-start justify-between mb-6">
    <div class="flex items-center gap-3">
      {logo ? (
        <img src={logo} alt={company} class="h-10 object-contain brightness-90 group-hover:brightness-100 transition-all" />
      ) : (
        <div class="w-12 h-12 rounded-xl bg-surface border border-surface-border flex items-center justify-center flex-shrink-0">
          <span class="font-display font-black text-brand-red text-sm">{initials}</span>
        </div>
      )}
      <div>
        <h3 class="font-display text-lg font-black text-text-primary group-hover:text-brand-red transition-colors">{company}</h3>
        <p class="text-xs font-mono text-text-muted">{industry}</p>
      </div>
    </div>
    <svg class="w-4 h-4 text-text-muted group-hover:text-brand-red group-hover:translate-x-1 transition-all flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
    </svg>
  </div>

  <!-- Outcome headline -->
  <p class="text-text-secondary text-sm leading-relaxed flex-1 mb-6">"{outcome}"</p>

  <!-- Key metrics -->
  {metrics.length > 0 && (
    <div class={`grid gap-4 mb-6 ${metrics.length === 2 ? 'grid-cols-2' : metrics.length === 3 ? 'grid-cols-3' : 'grid-cols-2'}`}>
      {metrics.map((m) => (
        <div class="bg-surface rounded-lg p-3 text-center border border-surface-border">
          <div class="font-display text-xl font-black text-brand-red">{m.value}</div>
          <div class="text-xs text-text-muted mt-0.5">{m.label}</div>
        </div>
      ))}
    </div>
  )}

  <!-- Services used -->
  <div class="flex flex-wrap gap-2">
    {services.map((s) => (
      <span class="text-xs px-2 py-1 rounded bg-surface border border-surface-border text-text-secondary font-mono">{s}</span>
    ))}
  </div>
</a>
