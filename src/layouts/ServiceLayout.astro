---
/**
 * ServiceLayout — shared layout for all service/consulting pages
 * Pattern: PageHero → What we do → Process → Deliverables → Related → CTA
 */
import BaseLayout from './BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import FeatureGrid from '../components/ui/FeatureGrid.astro';
import CTA from '../components/sections/CTA.astro';
import Badge from '../components/ui/Badge.astro';

interface Step { step: string; title: string; description: string }
interface Feature { icon?: string; title: string; description: string }
interface Deliverable { title: string; description: string }
interface Related { label: string; href: string; description: string }

interface Props {
  title: string;
  description: string;
  label: string;
  headline: string;
  highlightWord?: string;
  subtext: string;
  badge?: string;
  primaryCta?: { label: string; href: string };
  features: Feature[];
  process?: Step[];
  deliverables?: Deliverable[];
  related?: Related[];
  ctaHeadline?: string;
  ctaSubtext?: string;
}

const {
  title, description,
  label, headline, highlightWord, subtext, badge,
  primaryCta = { label: 'Discuss your Setup', href: '/contact' },
  features, process = [], deliverables = [], related = [],
  ctaHeadline, ctaSubtext,
} = Astro.props;
---

<BaseLayout {title} {description}>
  <PageHero {label} {headline} {highlightWord} {subtext} {badge} primaryCta={primaryCta} />

  <!-- What we do -->
  <section class="py-16 lg:py-24">
    <div class="container-site">
      <div class="mb-12 animate-on-scroll">
        <p class="section-label mb-3">What's included</p>
        <h2 class="font-display text-display-md font-black text-text-primary">Everything you need</h2>
      </div>
      <FeatureGrid {features} cols={3} />
    </div>
  </section>

  <!-- Process -->
  {process.length > 0 && (
    <section class="py-16 bg-background-secondary border-y border-surface-border">
      <div class="container-site">
        <div class="mb-12 animate-on-scroll">
          <p class="section-label mb-3">How it works</p>
          <h2 class="font-display text-display-md font-black text-text-primary">Our process</h2>
        </div>
        <div class="relative">
          <!-- Connector line -->
          <div class="hidden lg:block absolute top-8 left-8 right-8 h-px bg-gradient-to-r from-transparent via-surface-border to-transparent"></div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {process.map((step, i) => (
              <div class="card p-6 animate-on-scroll" style={`animation-delay:${i*120}ms`}>
                <div class="w-10 h-10 rounded-full bg-brand-red text-white flex items-center justify-center font-display font-black text-sm mb-4">
                  {step.step}
                </div>
                <h3 class="font-display text-base font-bold text-text-primary mb-2">{step.title}</h3>
                <p class="text-sm text-text-secondary leading-relaxed">{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Deliverables -->
  {deliverables.length > 0 && (
    <section class="py-16">
      <div class="container-site">
        <div class="mb-12 animate-on-scroll">
          <p class="section-label mb-3">Deliverables</p>
          <h2 class="font-display text-display-md font-black text-text-primary">What you walk away with</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {deliverables.map((d, i) => (
            <div class="flex items-start gap-4 p-5 rounded-xl border border-surface-border bg-background-card animate-on-scroll" style={`animation-delay:${i*80}ms`}>
              <div class="w-5 h-5 rounded-full bg-brand-red/10 border border-brand-red/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-brand-red" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-sm text-text-primary mb-0.5">{d.title}</p>
                <p class="text-xs text-text-secondary leading-relaxed">{d.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related services -->
  {related.length > 0 && (
    <section class="py-16 border-t border-surface-border">
      <div class="container-site">
        <div class="mb-10 animate-on-scroll">
          <p class="section-label mb-3">Related Services</p>
          <h2 class="font-display text-display-sm font-black text-text-primary">Often paired with</h2>
        </div>
        <div class="flex flex-wrap gap-4">
          {related.map(r => (
            <a href={r.href} class="card px-5 py-4 group hover:border-brand-red/40 transition-all animate-on-scroll">
              <p class="font-display font-bold text-sm text-text-primary group-hover:text-brand-red transition-colors">{r.label}</p>
              <p class="text-xs text-text-muted mt-0.5">{r.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <slot />

  <CTA headline={ctaHeadline} subtext={ctaSubtext} />
</BaseLayout>
