---
/**
 * CampaignLayout — minimal layout for ad campaign and landing pages
 * No main nav. Focused CTA only. Logo links home.
 * Use for: /lp/*, ad campaigns, webinar registrations
 */
import SEO from '../components/ui/SEO.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}
const { title, description, image, noindex = true } = Astro.props;
const GA_ID = import.meta.env.PUBLIC_GA_ID || 'G-XXXXXXXXXX';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <SEO {title} {description} {image} noindex={noindex} />
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
  <script define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA_ID);
  </script>
</head>
<body>
  <!-- Minimal header: logo only -->
  <header class="border-b border-surface-border">
    <div class="container-site h-14 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-7 h-7 bg-brand-red rounded-lg flex items-center justify-center">
          <span class="text-white font-display font-black text-xs">S</span>
        </div>
        <span class="font-display font-black text-lg text-text-primary tracking-tight">STAKATER</span>
      </a>
      <a href="/contact" class="btn-primary text-sm py-2 px-4">Contact Us</a>
    </div>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <!-- Minimal footer -->
  <footer class="border-t border-surface-border py-8 mt-16">
    <div class="container-site flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
      <p>© {new Date().getFullYear()} Stakater AB</p>
      <div class="flex gap-6">
        <a href="/privacy-policy" class="hover:text-text-primary transition-colors">Privacy Policy</a>
        <a href="/" class="hover:text-text-primary transition-colors">stakater.com</a>
      </div>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  </script>
</body>
</html>
